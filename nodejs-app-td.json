{
  "family": "nodejs-app-td",
  "taskRoleArn": "arn:aws:iam::127424156127:role/ecsTasksExecutionRole",
  "executionRoleArn": "arn:aws:iam::127424156127:role/ecsTasksExecutionRole",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "nodejsapp",
      "image": "127424156127.dkr.ecr.us-west-2.amazonaws.com/nodejs-app:latest",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 5000,
          "hostPort": 5000,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [],
      "mountPoints": [],
      "volumesFrom": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/nodejs-app-td",
          "awslogs-region": "us-west-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "volumes": [],
  "placementConstraints": [],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}